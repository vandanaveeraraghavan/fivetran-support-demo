# Fivetran Support Portal – Backend Environment Variables
# Copy this file to .env and fill in values before starting the server.

# Path to the claude CLI binary (auto-detected if on PATH)
# CLAUDE_BIN=/usr/local/bin/claude

# Override the FivetranKnowledge MCP server URL if it ever changes
# FIVETRAN_MCP_URL=https://api.triage.cx/oauth-server/mcp?kb_name=FivetranKnowledge

# Port the API server listens on (default: 3001)
# PORT=3001

# Zendesk sandbox credentials for ticket creation
# Get the API token from: https://{subdomain}.zendesk.com/admin/apps-integrations/apis/zendesk-api
ZENDESK_EMAIL=your-email@fivetran.com
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_SUBDOMAIN=fivetran18131705608885
